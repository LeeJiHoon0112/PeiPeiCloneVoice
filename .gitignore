# Môi trường ảo (KHÔNG đẩy lên GitHub — quá nặng, máy khác tự tạo)
venv/
env/

# Model tải về (~4.7GB — quá nặng cho GitHub, máy khác tự tải lần đầu)
models/

# Dữ liệu người dùng (giọng đã tạo + audio xuất ra)
user_data/

# Python
__pycache__/
*.pyc
*.pyo

# File tạm / kết quả
*.wav
*.log
# Script test tạm (đặt tên _xxx.py) — nhưng KHÔNG bỏ qua __init__.py của package
_*.py
!**/__init__.py

# Ghi chú nội bộ khi phát triển (không cần cho người dùng)
context.md

# Output đóng gói / che mã (không commit — build trên máy, có thể nặng GB)
build/
build_obf/
dist/
release/
*.exe
*.pyd
pyarmor_runtime*/
.pyarmor/

# IDE / OS
.vscode/
.idea/
Thumbs.db
desktop.ini
